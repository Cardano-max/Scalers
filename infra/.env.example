# Scalers local stack — copy to .env and adjust as needed.
# All ports are configurable to avoid clashes with other local services.

# ── Postgres + pgvector ───────────────────────────────────────────────
POSTGRES_USER=scalers
POSTGRES_PASSWORD=scalers
POSTGRES_DB=scalers
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ── MinIO (S3-compatible object store) ────────────────────────────────
MINIO_ROOT_USER=scalers
MINIO_ROOT_PASSWORD=scalers-dev-secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
# Bucket created on first boot by the minio-init one-shot service.
MINIO_BUCKET=scalers-assets

# ── Convenience connection strings (for app .env wiring) ──────────────
# DATABASE_URL=postgresql://scalers:scalers@localhost:5432/scalers
# REDIS_URL=redis://localhost:6379/0
# S3_ENDPOINT=http://localhost:9000
