{
  "uid": "scalers-engine-internals",
  "title": "Scalers — Engine Internals",
  "tags": ["scalers", "engine", "13u"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "tenant",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "scalers-prometheus" },
        "query": "label_values(scalers_runs_total, tenant)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Run rate by status",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "scalers-prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 15, "stacking": { "mode": "normal" } } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "sum"] } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(scalers_runs_total{tenant=~\"$tenant\"}[$__rate_interval])) by (status)", "legendFormat": "{{status}}" }
      ]
    },
    {
      "id": 2,
      "title": "Run failure %",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "scalers-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100, "decimals": 1,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 15 } ] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [
        { "refId": "A", "expr": "100 * sum(rate(scalers_runs_total{tenant=~\"$tenant\", status=~\"failed|error|timeout|crashed|cancelled\"}[$__rate_interval])) / clamp_min(sum(rate(scalers_runs_total{tenant=~\"$tenant\"}[$__rate_interval])), 1)" }
      ]
    },
    {
      "id": 3,
      "title": "Total run rate",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "scalers-prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops", "decimals": 2 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        { "refId": "A", "expr": "sum(rate(scalers_runs_total{tenant=~\"$tenant\"}[$__rate_interval]))" }
      ]
    },
    {
      "id": 4,
      "title": "Cell latency p95 (by cell)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "scalers-prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] } },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum(rate(scalers_cell_latency_seconds_bucket[$__rate_interval])) by (le, cell))", "legendFormat": "{{cell}}" }
      ]
    },
    {
      "id": 5,
      "title": "Autonomy decision mix (by outcome)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "scalers-prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 15, "stacking": { "mode": "normal" } } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(scalers_decisions_total{tenant=~\"$tenant\"}[$__rate_interval])) by (outcome)", "legendFormat": "{{outcome}}" }
      ]
    },
    {
      "id": 6,
      "title": "Gate checks (pass vs fail, by gate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "scalers-prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "sum"] } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(scalers_gate_checks_total{tenant=~\"$tenant\"}[$__rate_interval])) by (gate, result)", "legendFormat": "{{gate}} · {{result}}" }
      ]
    },
    {
      "id": 7,
      "title": "Gate failure %",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "scalers-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100, "decimals": 1,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 30 } ] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        { "refId": "A", "expr": "100 * sum(rate(scalers_gate_checks_total{tenant=~\"$tenant\", result=\"fail\"}[$__rate_interval])) / clamp_min(sum(rate(scalers_gate_checks_total{tenant=~\"$tenant\"}[$__rate_interval])), 1)" }
      ]
    },
    {
      "id": 8,
      "title": "Side-effect outcomes (by outcome)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "scalers-prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 15, "stacking": { "mode": "normal" } } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(scalers_side_effects_total{tenant=~\"$tenant\"}[$__rate_interval])) by (outcome)", "legendFormat": "{{outcome}}" }
      ]
    }
  ]
}
