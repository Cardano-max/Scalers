{
  "uid": "scalers-overview",
  "title": "Scalers — Engine Overview",
  "tags": ["scalers", "engine"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "tenant",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "scalers-prometheus" },
        "query": "label_values(scalers_decisions_total, tenant)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Autonomy % (auto vs total decisions)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "scalers-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 50 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(rate(scalers_decisions_total{outcome=\"auto\", tenant=~\"$tenant\"}[$__rate_interval])) / clamp_min(sum(rate(scalers_decisions_total{tenant=~\"$tenant\"}[$__rate_interval])), 1)"
        }
      ]
    },
    {
      "id": 2,
      "title": "Complaint rate (complaints / published)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "scalers-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(rate(scalers_complaints_total{tenant=~\"$tenant\"}[$__rate_interval])) / clamp_min(sum(rate(scalers_actions_published_total{tenant=~\"$tenant\"}[$__rate_interval])), 1)"
        }
      ]
    },
    {
      "id": 3,
      "title": "Publish quota used % (IG content_publishing_limit)",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "scalers-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(scalers_publish_quota_used{tenant=~\"$tenant\"}) by (tenant, channel) / clamp_min(sum(scalers_publish_quota_limit{tenant=~\"$tenant\"}) by (tenant, channel), 1)"
        }
      ]
    },
    {
      "id": 4,
      "title": "Queue depth",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "scalers-prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(scalers_queue_depth{tenant=~\"$tenant\"}) by (queue)",
          "legendFormat": "{{queue}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Run latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "scalers-prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] } },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum(rate(scalers_run_latency_seconds_bucket{tenant=~\"$tenant\"}[$__rate_interval])) by (le))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum(rate(scalers_run_latency_seconds_bucket{tenant=~\"$tenant\"}[$__rate_interval])) by (le))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum(rate(scalers_run_latency_seconds_bucket{tenant=~\"$tenant\"}[$__rate_interval])) by (le))",
          "legendFormat": "p99"
        }
      ]
    }
  ]
}
