# Scalers engine — local secrets template (engine-local override).
#
# Copy to `engine/.env` and fill in REAL values locally. `engine/.env` is
# gitignored and MUST NEVER be committed. PLACEHOLDERS ONLY in this template.
#
#   cp engine/.env.example engine/.env
#
# Loading order (highest precedence first), see engine/harness/config.py:
#   real exported env var  >  engine/.env  >  repo-root .env
# A real exported variable always wins; a missing file is a no-op.

# --- Anthropic (Claude) -----------------------------------------------------
# REQUIRED from Phase 2 (eval spine runs real model calls). Read natively by
# Pydantic-AI. https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# --- Foreplay ---------------------------------------------------------------
# REQUIRED from Phase 3 (ad research; 10k free credits/mo). Errors only at
# use time if missing — not needed before Phase 3.
FOREPLAY_API_KEY=REPLACE_ME

# --- Durable run / checkpointer (fr1.2) -------------------------------------
# ACTIVATION FLAG for durability. When set, engine/harness/config.py's
# make_checkpointer() flips from the in-memory saver to the durable LangGraph
# Postgres checkpointer, and archetypes/compose.run_campaign compiles the
# campaign graph with the SYNC PostgresSaver — so a laptop reboot mid-campaign
# resumes at the exact node/lead being drafted instead of losing the run.
# Unset -> in-memory (ephemeral): a crash loses in-flight runs.
# REQUIRES the `postgres` extra installed (`uv sync --extra postgres`; CI and
# the deploy image already do this). Point it at the local Docker Postgres:
ENGINE_DATABASE_URL=postgresql://scalers:scalers@localhost:5432/scalers
