# Scalers — local secrets template.
#
# Copy this file to `.env` (same directory) and fill in REAL values locally.
# `.env` is gitignored and MUST NEVER be committed. This template carries
# PLACEHOLDERS ONLY — never paste a real key here.
#
#   cp .env.example .env      # then edit .env with your real keys
#
# Loading: engine/harness/config.py loads `.env` at startup into the process
# environment. A real exported environment variable always wins over `.env`
# (so CI/prod inject real vars and ignore any stray file). The engine also
# reads an engine-local `engine/.env` if present (see engine/.env.example).

# --- Anthropic (Claude) -----------------------------------------------------
# REQUIRED from Phase 2 (eval spine runs real model calls). Pydantic-AI reads
# this variable natively. Get a key at https://console.anthropic.com/.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# --- Foreplay ---------------------------------------------------------------
# REQUIRED from Phase 3 (ad research; 10k free credits/mo). Not needed before
# Phase 3 — a missing value only errors when the research path actually uses it.
FOREPLAY_API_KEY=REPLACE_ME
