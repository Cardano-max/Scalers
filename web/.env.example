# Scalers Operator Console — frontend env template.
# Copy to `.env.local` (gitignored) and adjust for your environment.

# Data source for the console's data layer.
#   mock = the clearly-labeled in-memory mock adapter (kkg.4 contract shapes,
#          no backend required). Use until the kkg.4 GraphQL+SSE API is live.
#   live = bind to the real kkg.4 gateway (GraphQL + SSE) below.
# Default when unset: mock.
NEXT_PUBLIC_DATA_SOURCE=mock

# kkg.4 read API (eng1 / NestJS gateway). Flip NEXT_PUBLIC_DATA_SOURCE=live
# and point these at the gateway the moment kkg.4 ships.
#   GraphQL: POST {GRAPHQL_URL}
#   SSE:     GET  {SSE_URL}?tenantId=...        (multiplexed: feed.event,
#            action.created/updated, run.updated, kpi.updated, health.updated, toast)
#            GET  {SSE_FEED_URL}?tenantId=...    (feed-only convenience stream)
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql
NEXT_PUBLIC_SSE_URL=http://localhost:4000/sse/stream
NEXT_PUBLIC_SSE_FEED_URL=http://localhost:4000/sse/feed

# The single active tenant shown in the UI (backend is multi-tenant via RLS;
# this id is carried in every GraphQL query + SSE subscription).
NEXT_PUBLIC_TENANT_ID=northwind

# ── Campaign Studio (P3.1 live AG-UI) ───────────────────────────────────────
# Point the chat-first Campaign Studio at the live AG-UI backend (engine
# /studio/agui). When SET, the Command tab binds to the real Studio Host + role
# cells (editable shared-state plan + approval gate). When UNSET, the studio
# renders the honest preview scaffold (never a fake exchange).
# Use a same-origin path so the Next rewrite proxies to the engine (no CORS):
NEXT_PUBLIC_STUDIO_AGUI_URL=/studio/agui
NEXT_PUBLIC_STUDIO_GRAPHQL_URL=/graphql
# Engine origin the Next rewrites proxy to (server-side only):
STUDIO_BACKEND_ORIGIN=http://127.0.0.1:8002
