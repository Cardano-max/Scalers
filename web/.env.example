# Scalers Operator Console — frontend env template.
# Copy to `.env.local` (gitignored) and adjust for your environment.

# Data source for the console's data layer.
#   live = bind to the REAL engine read API (obsapi GraphQL + SSE) below. The
#          non-studio tabs render real runs + actions. THIS IS THE DEFAULT.
#   mock = the clearly-labeled in-memory mock adapter (contract shapes, no
#          backend required) — a clean offline/demo fallback.
# Default when unset: live.
NEXT_PUBLIC_DATA_SOURCE=live

# Engine read API (obsapi: POST /graphql, GET /sse/stream + /sse/feed). The
# defaults are SAME-ORIGIN paths so next.config rewrites proxy them to
# STUDIO_BACKEND_ORIGIN (default http://127.0.0.1:8010) — no CORS, any port.
#   GraphQL: POST {GRAPHQL_URL}
#   SSE:     GET  {SSE_URL}?tenantId=...        (multiplexed: feed.event,
#            action.created/updated, run.updated, kpi.updated, health.updated, toast)
#            GET  {SSE_FEED_URL}?tenantId=...    (feed-only convenience stream)
NEXT_PUBLIC_GRAPHQL_URL=/graphql
NEXT_PUBLIC_SSE_URL=/sse/stream
NEXT_PUBLIC_SSE_FEED_URL=/sse/feed

# The single active tenant shown in the UI (backend is multi-tenant via RLS;
# this id is carried in every GraphQL query + SSE subscription). The live demo
# tenant whose real campaign runs + drafts back these tabs is ladies8391.
NEXT_PUBLIC_TENANT_ID=ladies8391

# Show dev fixture tenants (e.g. "Ladies First (dev fixture)") in the operator
# tenant switcher. Unset/0 = hidden (operator-facing default); 1/true = shown.
# NEXT_PUBLIC_SHOW_FIXTURE_TENANTS=1

# ── Campaign Studio (P3.1 live AG-UI) ───────────────────────────────────────
# Point the chat-first Campaign Studio at the live AG-UI backend (engine
# /studio/agui). When SET, the Command tab binds to the real Studio Host + role
# cells (editable shared-state plan + approval gate). When UNSET, the studio
# renders the honest preview scaffold (never a fake exchange).
# Use a same-origin path so the Next rewrite proxies to the engine (no CORS):
NEXT_PUBLIC_STUDIO_AGUI_URL=/studio/agui
NEXT_PUBLIC_STUDIO_GRAPHQL_URL=/graphql
# Engine origin the Next rewrites proxy /graphql + /sse/* + /studio/* to
# (server-side only). The integrated go-live engine (obsapi) runs on :8010.
STUDIO_BACKEND_ORIGIN=http://127.0.0.1:8010
